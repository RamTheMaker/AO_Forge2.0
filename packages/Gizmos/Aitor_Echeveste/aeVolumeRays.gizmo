Group {
 name aeVolumeRays6
 tile_color 0xa8905cff
 note_font "Verdana Bold"
 selected true
 xpos -315
 ypos -214
 addUserKnob {20 aeVolumeRays}
 addUserKnob {26 maindiv_quality l "" +STARTLINE T "<b><font color=#ffffff>Quality </font><b>"}
 addUserKnob {26 "" -STARTLINE}
 addUserKnob {41 format l "output format" T Reformat24.format}
 addUserKnob {41 main_num_steps l steps T num_steps}
 addUserKnob {26 text_7 l "  " -STARTLINE T "  "}
 addUserKnob {6 preview -STARTLINE}
 addUserKnob {26 ""}
 addUserKnob {26 maindiv_look l "" +STARTLINE T "<b><font color=#ffffff>Look </font><b>"}
 addUserKnob {26 "" -STARTLINE}
 addUserKnob {41 main_brightness l brightness T brightness}
 addUserKnob {41 falloff_exponent_1 l falloff T falloff_exponent}
 addUserKnob {41 hit_surface_1 l "hit surface" T hit_surface}
 addUserKnob {26 ""}
 addUserKnob {26 text l "" +STARTLINE T "<b><font color=#ffffff>Shape  </font><b>"}
 addUserKnob {26 "" -STARTLINE}
 addUserKnob {41 main_cone_edge l "cone edge fade" T cone_edge_fade}
 addUserKnob {41 cookie_strength_link l "cookie strength" T cookie_strength}
 addUserKnob {26 ""}
 addUserKnob {26 text_1 l "" +STARTLINE T "<span style=\"color:#666\"><br/><b>aeVolumeRays v1.0</b> - <a  style=\"color:#666;text-decoration: none;\">Aitor Echeveste</a>  © 2026</span>"}
 addUserKnob {20 Rays}
 addUserKnob {26 div_look l "" +STARTLINE T "<b><font color=#ffffff>Look </font><b>"}
 addUserKnob {26 "" -STARTLINE}
 addUserKnob {7 brightness t "Final intensity multiplier." R 0 50}
 brightness 5
 addUserKnob {7 falloff_exponent l falloff t "custom falloff" R 0 100}
 falloff_exponent 100
 addUserKnob {7 extinction t "Volume density. Higher = light attenuates faster."}
 extinction 0.1
 addUserKnob {18 color_near l color t "Color of samples close to the light."}
 color_near {1 1 1}
 addUserKnob {6 color_near_panelDropped l "panel dropped state" -STARTLINE +HIDDEN}
 addUserKnob {6 color_far_panelDropped l "panel dropped state" +HIDDEN +STARTLINE}
 addUserKnob {26 ""}
 addUserKnob {6 haze_color_panelDropped l "panel dropped state" -STARTLINE +HIDDEN}
 addUserKnob {26 text_3 l "" +STARTLINE T "<b><font color=#ffffff>Cone / Shaft </font><b>"}
 addUserKnob {26 "" -STARTLINE}
 addUserKnob {7 cone_edge_fade l "cone edge fade" t "Softness of the cone border." R 1 3}
 cone_edge_fade 2
 addUserKnob {7 shaft_softness_distance l "softness w/ distance" t "Soften shaft borders with distance from the light." R 0 2}
 addUserKnob {7 hit_surface l "hit surface"}
 hit_surface 0.25
 addUserKnob {7 ambient_scatter l ambient t "Lifts shadowed regions inside the shaft." R 0 0.1}
 addUserKnob {26 ""}
 addUserKnob {26 text_2 l "" +STARTLINE T "<b><font color=#ffffff>Cookie / Gobo </font><b>"}
 addUserKnob {26 "" -STARTLINE}
 addUserKnob {7 cookie_strength l "alpha strength" t "Cookie alpha modulates intensity."}
 addUserKnob {7 cookie_color_strength l "color strength" t "Cookie RGB tints the shaft (stained glass)."}
 addUserKnob {20 Volumetric}
 addUserKnob {26 div_volume_range l "" +STARTLINE T "<b><font color=#ffffff>Volume Range </font><b>"}
 addUserKnob {26 "" -STARTLINE}
 addUserKnob {7 vol_near l near t "Start of raymarch range. Link to camR.near." R 0 10000}
 vol_near 0.1
 addUserKnob {7 vol_far l far t "End of raymarch range. Link to camR.far." R 0 100000}
 vol_far 50
 addUserKnob {26 ""}
 addUserKnob {26 div_volumetric_noise l "" +STARTLINE T "<b><font color=#ffffff>Volumetric Noise </font><b>"}
 addUserKnob {26 text_4 l " " -STARTLINE T " "}
 addUserKnob {6 noise_enable l "enable noise" t "Enable dual-octave 3D noise on density." -STARTLINE}
 addUserKnob {7 noise_scale_low l "low scale" t "Size of low-frequency structure." R 0.01 100}
 noise_scale_low 0.5
 addUserKnob {7 noise_strength_low l "low strength" t "Intensity of low-frequency noise."}
 noise_strength_low 1
 addUserKnob {26 ""}
 addUserKnob {7 noise_scale_high l "high scale" t "Size of high-frequency detail." R 0.01 50}
 noise_scale_high 0.05
 addUserKnob {7 noise_strength_high l "high strength" t "Intensity of high-frequency noise."}
 noise_strength_high 0.5
 addUserKnob {13 offsetNoise l offset}
 addUserKnob {26 ""}
 addUserKnob {26 div_atmospheric_haze l "" +STARTLINE T "<b><font color=#ffffff>Atmospheric Haze </font><b>"}
 addUserKnob {26 "" -STARTLINE}
 addUserKnob {7 haze_density l density t "Strength of the global haze layer."}
 addUserKnob {7 haze_distance l distance t "Reference distance. Larger = subtler haze." R 0 1000}
 haze_distance 50
 addUserKnob {18 haze_color l color t "Tint of the atmospheric haze."}
 haze_color 1
 addUserKnob {6 haze_color_panelDropped l "panel dropped state" -STARTLINE +HIDDEN}
 addUserKnob {20 Setup}
 addUserKnob {26 div_quality l "" +STARTLINE T "<b><font color=#ffffff>Quality </font><b>"}
 addUserKnob {26 "" -STARTLINE}
 addUserKnob {3 num_steps l steps t "Raymarch samples. 32 preview / 128+ final." R 1 512}
 num_steps 512
 addUserKnob {7 jitter t "Sampling dithering to break banding." +INVISIBLE}
 jitter 1
 addUserKnob {41 overscan T sr_beauty7.overscan}
 addUserKnob {41 stochastic_samples l stochastic T sr_beauty7.stochastic_samples}
 addUserKnob {26 ""}
 addUserKnob {26 text_5 l "" +STARTLINE T "<b><font color=#ffffff>Scattring (Heyyey-Greenstein) </font><b>"}
 addUserKnob {26 "" -STARTLINE}
 addUserKnob {7 hg_g l anisotropy t ">0 = forward (god rays), <0 = back, 0 = isotropic." R -0.95 0.95}
 hg_g 0.5
 addUserKnob {7 hg_strength l "hg strength" t "Blend isotropic (0) -> HG (1)."}
 hg_strength 0.8
 addUserKnob {26 ""}
 addUserKnob {26 div_holdout l "" +STARTLINE T "<b><font color=#ffffff>Holdout </font><b>"}
 addUserKnob {26 text_6 l "  " -STARTLINE T "  "}
 addUserKnob {6 holdout_enable l "enable holdout" t "Cut shaft where opaque geometry occludes it." -STARTLINE}
 holdout_enable true
 addUserKnob {7 holdout_epsilon l epsilon t "Min valid depth value." R 0 0.01}
 holdout_epsilon 0.02
 addUserKnob {7 holdout_softness l "edge softness" t "Soft fade at the holdout edge (scene units)." R 0 5}
 addUserKnob {26 ""}
 addUserKnob {26 div_shadow l "" +STARTLINE T "<b><font color=#ffffff>Shadow  </font><b>"}
 addUserKnob {26 "" -STARTLINE}
 addUserKnob {7 shadow_bias l bias t "Removes self-shadow acne." R 0 0.005}
 shadow_bias 0.0011
 addUserKnob {7 pcf_radius l softness t "Shadow blur radius in pixels." R 0 20}
 addUserKnob {20 About}
 addUserKnob {26 text_1_1 l "" +STARTLINE T "   "}
 addUserKnob {26 text_2_1 l "" +STARTLINE T "   "}
 addUserKnob {26 text_4_1 l "" +STARTLINE T "<font color=#ffffff><font size=\"7\">aeVolumeRays</font><font size=\"2\"> v1.0</font>\n"}
 addUserKnob {26 about_1_1 l "" +STARTLINE T "by Aitor Echeveste Izquierdo © 2026"}
 addUserKnob {26 text_1_1_1 l "" +STARTLINE T "   "}
 addUserKnob {26 ""}
 addUserKnob {26 text_3_1 l "" +STARTLINE T "   "}
 addUserKnob {26 website l "" +STARTLINE T "<b><a href=\"http://www.aitorecheveste.com\"><span style=\"color:#C8C8C8;\">www.aitorecheveste.com</span></a><b>"}
}
